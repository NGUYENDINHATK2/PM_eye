NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Use EITHER of the two below (Supabase has both old & new names).
# Find it in Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# or, if your Supabase project shows "publishable key":
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# ---- Admin RBAC (server-side, không expose) ----
# CSV email được coi là admin ở tầng Next.js API.
# Vẫn phải set { "role": "admin" } trong Supabase App Metadata để pass RLS.
# ADMIN_EMAILS=ban@cong-ty.com

# ---- HTTP Basic Auth gate (optional) ----
# Bật để pop dialog "Enter password" trước khi vào site (cả /login).
# Format: "username:password". Để trống nếu không muốn dùng.
# Vercel: Project Settings → Environment Variables → Add → SITE_BASIC_AUTH
# SITE_BASIC_AUTH=team:supersecretpassword
